# Firebase Configuration - Alpha Premier Group
# Copy this file to .env.local and fill in your real Firebase config
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=alphapremier-group.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=alphapremier-group
# VITE_FIREBASE_STORAGE_BUCKET=alphapremier-group.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
# VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
