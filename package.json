{
  "name": "alpha-premier-group",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Alpha Premier Group — Vite + React SPA (migrated from Firebase to Supabase)",
  "scripts": {
    "dev": "concurrently --kill-others \"vite\" \"node server/contact.js\"",
    "dev:contact": "node server/contact.js",
    "dev:all": "concurrently --kill-others \"pnpm dev\" \"pnpm dev:contact\"",
    "build": "vite build",
    "preview": "vite preview",
    "migrate-to-supabase": "node scripts/migrate-to-supabase.cjs || supabase db push",
    "setup-admin": "node scripts/setup-admin.cjs",
    "seed-archived-context": "node scripts/seed-archived-context.mjs",
    "seed-job-openings": "node scripts/seed-job-openings.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.3",
    "aos": "^2.3.4",
    "dotenv": "^16.4.7",
    "lucide-react": "^0.487.0",
    "motion": "^12.42.2",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.9.1",
    "resend": "^6.16.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "vite": "^5.4.11"
  }
}
