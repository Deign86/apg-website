# Supabase Configuration - Alpha Premier Group
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and holds your actual secrets.
#
# Get these values from your Supabase project:
#   Project Settings → API → Project URL / anon key / service_role key
#
# IMPORTANT: The SUPABASE_SERVICE_ROLE_KEY must NEVER be exposed to the client.
# It is used only by the Node.js server (server/contact.js, scripts/setup-admin.cjs).
# VITE_-prefixed variables are safe for the client (bundled by Vite).

# === Required: Supabase (client + server) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-goes-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-goes-here

# === Required: Resend Email API (server only) ===
RESEND_API_KEY=re_your-resend-api-key
COMPANY_EMAIL=your-email@example.com

# === Optional: NVIDIA NIM AI (chatbot + dashboard insights) ===
# Get a free key at https://build.nvidia.com (API Keys). Server-side ONLY.
# This single key powers the public chatbot AND admin AI analysis.
NVIDIA_API_KEY=nvapi_your-nvidia-key-here
# Default model (free endpoint). Override only if you want a different NIM model.
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# Points the existing insights.js LLM seam at our own /api/ai/insights endpoint.
# Safe relative path — no key is exposed to the client.
VITE_INSIGHTS_API_URL=/api/ai/insights

# === Required for Google Drive property listings sync (scripts/sync-drive-listings.cjs) ===
# Create a Google Cloud project, enable the Drive API, create a service account,
# share the APR LISTING Drive folder with the service account email (Viewer role),
# then provide credentials via ONE of these methods:
#
# Option A: Inline service-account JSON (path to file OR inline JSON string)
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/apr-sync-key.json
#
# Option B: Inline key (JWT auth from individual fields)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"
#
# Option C: Google application credentials file path
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/apr-sync-key.json
#
# The canonical APR LISTING Drive folder ID:
GOOGLE_DRIVE_FOLDER_ID=1GXeGULYswb7jXcMGCCRm2RQ_h0EKsDll
